{
  "iteration": "{{[0]}}",
  "tw-fields": {
    "title": "Moodle: {{subject}} ({{userfullname}}, {{id}})",
    "text":  { "value": "{{message}}", "transform": "html-to-wikitext" }
  },
  "custom-fields": {
    "moodle-id":         { "value": "{{id}}",            "transform": "to-string" },
    "moodle-discussion": { "value": "{{discussion}}",    "transform": "to-string" },
    "moodle-author":     "{{userfullname}}",
    "moodle-userid":     { "value": "{{userid}}",        "transform": "to-string" },
    "moodle-created":    "{{created}}",
    "moodle-modified":   "{{modified}}",
    "moodle-wordcount":  { "value": "{{wordcount}}",     "transform": "to-string" },
    "moodle-charcount":  { "value": "{{charcount}}",     "transform": "to-string" }
  }
}
