tags: $:/tags/Stylesheet
title: $:/json-convert/styles/screenshot
type: text/css

.screenshot { display: block; margin: auto; }

/* Inline TW SVG icon, sized to match surrounding text. */
.jc-inline-icon {
	display: inline-block;
	width: 1em;
	height: 1em;
	vertical-align: -0.15em;
}
.jc-inline-icon svg {
	width: 100%;
	height: 100%;
	fill: currentColor;
}
