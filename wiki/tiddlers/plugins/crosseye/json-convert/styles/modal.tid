title: $:/plugins/crosseye/json-convert/styles/modal
tags: $:/tags/Stylesheet
type: text/css

.jc-path-modal {
	min-width: 32em;
	max-width: 56em;
}

.jc-path-modal h2 {
	margin-top: 0.25em;
	font-size: 1.1em;
}

.jc-path-modal small {
	display: block;
	margin-bottom: 0.5em;
	color: #666;
}

.jc-path-modal .jc-tree {
	max-height: 22em;
	overflow-y: auto;
}

.jc-path-modal-footer {
	margin-top: 0.75em;
	display: flex;
	justify-content: flex-end;
}
