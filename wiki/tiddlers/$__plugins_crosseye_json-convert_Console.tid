caption: JSON Convert
created: 20260506120908868
modified: 20260506120911486
title: $:/plugins/crosseye/json-convert/Console
type: text/vnd.tiddlywiki

<$let
  state-base=<<qualify "$:/state/json-convert">>
  staged-base=<<qualify "$:/temp/json-convert/staged">>
  source-title={{{ [<state-base>addsuffix[/source]] }}}
  profile-title={{{ [<state-base>addsuffix[/profile]] }}}
  errors-title={{{ [<state-base>addsuffix[/result/errors]] }}}
  warnings-title={{{ [<state-base>addsuffix[/result/warnings]] }}}
  collisions-title={{{ [<state-base>addsuffix[/result/collisions]] }}}
  staged-prefix={{{ [<staged-base>addsuffix[/]] }}}
  decisions-prefix={{{ [<state-base>addsuffix[/decisions/]] }}}
>

A general-purpose JSON-to-tiddler conversion tool. Pick a mapping profile,
paste your source JSON, and click ''Convert''.

!! 1. Profile

<$select tiddler=<<profile-title>>>
<option value="">— select a profile —</option>
<$list filter="[tag[$:/tags/json-convert/mapping]sort[]]">
<option value=<<currentTiddler>>><$view field="title"/></option>
</$list>
</$select>

!! 2. Source JSON

<$edit-text
  tiddler=<<source-title>>
  tag="textarea"
  rows="14"
  placeholder="Paste JSON here…"
  class="tc-edit-texteditor"
/>

!! 3. Run

<$button class="tc-btn-big-green">
Convert
<$json-convert-run state-base=<<state-base>> staged-base=<<staged-base>>/>
</$button>

!! Results

<$list filter="[<errors-title>has[title]]" emptyMessage="//No run yet — click ''Convert'' above.//" variable="ignore">

|!Category |!Count |
|Tiddlers staged |<$count filter="[prefix<staged-prefix>]"/> |
|Errors |<$count filter="[<errors-title>jsonindexes[]]"/> |
|Warnings |<$count filter="[<warnings-title>jsonindexes[]]"/> |
|Collisions |<$count filter="[<collisions-title>jsonindexes[]]"/> |

<$list filter="[<errors-title>jsonindexes[]first[]]" emptyMessage="" variable="_first">
<details><summary>Errors (<$count filter="[<errors-title>jsonindexes[]]"/>)</summary>
<$list filter="[<errors-title>jsonindexes[]]" variable="idx">
* ''{{{ [<errors-title>jsonget<idx>,[code]] }}}'' — {{{ [<errors-title>jsonget<idx>,[message]] }}}
</$list>
</details>
</$list>

<$list filter="[<warnings-title>jsonindexes[]first[]]" emptyMessage="" variable="_first">
<details><summary>Warnings (<$count filter="[<warnings-title>jsonindexes[]]"/>)</summary>
<$list filter="[<warnings-title>jsonindexes[]]" variable="idx">
* ''{{{ [<warnings-title>jsonget<idx>,[code]] }}}'' — {{{ [<warnings-title>jsonget<idx>,[message]] }}}
</$list>
</details>
</$list>

<$list filter="[<collisions-title>jsonindexes[]first[]]" emptyMessage="" variable="_first">
<details><summary>Collisions with existing titles (<$count filter="[<collisions-title>jsonindexes[]]"/>)</summary>
<$list filter="[<collisions-title>jsonindexes[]]" variable="idx">
* {{{ [<collisions-title>jsonget<idx>] }}}
</$list>
</details>
</$list>

</$list>

<$list filter="[prefix<staged-prefix>first[]]" emptyMessage="" variable="_first">

!! Staging

<$count filter="[prefix<staged-prefix>]"/> tiddlers staged. Pick an action for each, then click ''Apply'' to write them to the wiki, or ''Cancel'' to discard.

<$list filter="[prefix<staged-prefix>sort[]]" variable="stagedTitle">
<$let
  idx={{{ [<stagedTitle>removeprefix<staged-prefix>] }}}
  decisionTitle={{{ [<decisions-prefix>addsuffix<idx>] }}}
  expandedTitle={{{ [<state-base>addsuffix[/expanded/]addsuffix<idx>] }}}
  targetTitle={{{ [<stagedTitle>get[_target-title]] }}}
>
<div class="jc-staging-row">

<div class="jc-toggle">
<$reveal type="match" stateTitle=<<expandedTitle>> text="yes" tag="span">
<$button class="tc-btn-invisible">
<$action-setfield $tiddler=<<expandedTitle>> text="no"/>
{{$:/core/images/down-arrow}}
</$button>
</$reveal>
<$reveal type="nomatch" stateTitle=<<expandedTitle>> text="yes" tag="span">
<$button class="tc-btn-invisible">
<$action-setfield $tiddler=<<expandedTitle>> text="yes"/>
{{$:/core/images/right-arrow}}
</$button>
</$reveal>
</div>

<div class="jc-title">
<strong><$text text=<<targetTitle>>/></strong> {{{ [<stagedTitle>get[_collision]match[yes]then[(collides with existing)]] }}}
</div>

<div class="jc-actions">
<div>
<$radio tiddler=<<decisionTitle>> value="overwrite"> overwrite</$radio>
<$radio tiddler=<<decisionTitle>> value="rename"> rename</$radio>
<$radio tiddler=<<decisionTitle>> value="skip"> skip</$radio>
</div>
<$reveal type="match" stateTitle=<<decisionTitle>> text="rename" tag="div" class="jc-rename">
→ <$edit-text tiddler=<<decisionTitle>> field="rename-title" tag="input" placeholder=<<targetTitle>> default=<<targetTitle>>/>
</$reveal>
</div>

<$list filter="[<expandedTitle>get[text]match[yes]]" emptyMessage="" variable="_unused">
<div class="jc-expansion">

<table class="jc-fields-table">
<thead><tr><th>Field</th><th>Value</th></tr></thead>
<tbody>
<$list filter="[<stagedTitle>fields[]] -[[title]] -[[text]] -[[created]] -[[modified]] -[[_target-title]] -[[_collision]] +[sort[]]" variable="fieldName">
<tr><td><$text text=<<fieldName>>/></td><td>{{{ [<stagedTitle>get<fieldName>] }}}</td></tr>
</$list>
</tbody>
</table>

<div class="jc-staging-preview">
<$transclude $tiddler=<<stagedTitle>> $field="text" $type="text/vnd.tiddlywiki" $mode="block"/>
</div>

</div>
</$list>

</div>
</$let>
</$list>

<$button class="tc-btn-big-green">
Apply
<$json-convert-apply state-base=<<state-base>> staged-base=<<staged-base>>/>
</$button>
<$button>
Cancel
<$json-convert-cancel state-base=<<state-base>> staged-base=<<staged-base>>/>
</$button>

</$list>

</$let>
