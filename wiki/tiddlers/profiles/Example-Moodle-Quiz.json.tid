title: Example Moodle Quiz
type: application/json
tags: $:/tags/json-convert/profile

{
  "records": "{{questions[*]}}",
  "tw-fields": {
    "title": "{{course}}/{{name}}-{{id}}",
    "text":  "{{questionText|html-to-wikitext}}",
    "tags":  "{{category|split-commas}}",
