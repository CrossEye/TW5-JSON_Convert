{
  "iteration": "[0]",
  "tw-fields": {
    "title": {
      "template": "Moodle: {subject} ({userfullname}, {id})"
    },
    "text": {
      "path": "message",
      "transform": "html-to-wikitext"
    },
    "tags": {
      "literal": "Added"
    }
  },
  "custom-fields": {
    "moodle-id": {
      "path": "id",
      "transform": "to-string"
    },
    "moodle-discussion": {
      "path": "discussion",
      "transform": "to-string"
    },
    "moodle-author": {
      "path": "userfullname"
    },
    "moodle-userid": {
      "path": "userid",
      "transform": "to-string"
    },
    "moodle-created": {
      "path": "created"
    },
    "moodle-modified": {
      "path": "modified"
    },
    "moodle-wordcount": {
      "path": "wordcount",
      "transform": "to-string"
    },
    "moodle-charcount": {
      "path": "charcount",
      "transform": "to-string"
    }
  }
}