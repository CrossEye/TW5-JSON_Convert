caption: Pick fields
title: $:/plugins/crosseye/json-convert/Editor/PassThroughPickerModal
type: text/vnd.tiddlywiki
subtitle: Pick fields to import
footer: <$button class="tc-btn-mid-blue">Apply<$json-convert-picker-apply draft-base="$:/state/json-convert/editor/draft/" state-title="$:/state/json-convert/editor/picker" snapshot-title="$:/state/json-convert/editor/picker-open-snapshot" source-title={{$:/state/json-convert/editor/modal/source-title}} records-path={{$:/state/json-convert/editor/modal/records-path}}/><$json-convert-editor-write profile-title={{$:/state/json-convert/editor/profile-title}} draft-base="$:/state/json-convert/editor/draft/"/><$action-sendmessage $message="tm-close-tiddler" $param="$:/plugins/crosseye/json-convert/Editor/PassThroughPickerModal"/></$button> <$button>Cancel<$action-sendmessage $message="tm-close-tiddler" $param="$:/plugins/crosseye/json-convert/Editor/PassThroughPickerModal"/></$button>

<$let
  picker-state-title="$:/state/json-convert/editor/picker"
  modal-source-title={{$:/state/json-convert/editor/modal/source-title}}
  modal-records-path={{$:/state/json-convert/editor/modal/records-path}}
  draft-base="$:/state/json-convert/editor/draft/"
>

<div class="jc-path-modal jc-picker-modal">

<div class="jc-picker-header">
<$json-convert-picker-all
  source-title=<<modal-source-title>>
  records-path=<<modal-records-path>>
  draft-base=<<draft-base>>
  state-title=<<picker-state-title>>/>
</div>

<$json-convert-tree
  source-title=<<modal-source-title>>
  records-path=<<modal-records-path>>
  mode="field-pick"
  picker-state-title=<<picker-state-title>>
  draft-base=<<draft-base>>
/>

</div>

</$let>
