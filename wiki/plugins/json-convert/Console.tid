caption: JSON Convert
created: 20260506120908868
icon: $:/plugins/crosseye/json-convert/icon
modified: 20260506120911486
title: $:/plugins/crosseye/json-convert/Console
type: text/vnd.tiddlywiki

\procedure jc-staging-row()
<$let
  idx={{{ [<stagedTitle>removeprefix<staged-prefix>] }}}
  decisionTitle={{{ [<decisions-prefix>addsuffix<idx>] }}}
  expandedTitle={{{ [<state-base>addsuffix[/expanded/]addsuffix<idx>] }}}
  targetTitle={{{ [<stagedTitle>get[_target-title]] }}}
>
<div class="jc-staged-item">
<div class="jc-staged-header">

<div class="jc-toggle">
<$reveal type="match" stateTitle=<<expandedTitle>> text="yes" tag="span">
<$button class="tc-btn-invisible">
<$action-setfield $tiddler=<<expandedTitle>> text="no"/>
{{$:/core/images/down-arrow}}
</$button>
</$reveal>
<$reveal type="nomatch" stateTitle=<<expandedTitle>> text="yes" tag="span">
<$button class="tc-btn-invisible">
<$action-setfield $tiddler=<<expandedTitle>> text="yes"/>
{{$:/core/images/right-arrow}}
</$button>
</$reveal>
</div>

<div class="jc-title">
<strong><$text text=<<targetTitle>>/></strong>
</div>

<div class="jc-actions">
<$list filter="[<stagedTitle>has[_collision]first[]]" variable="_jc" emptyMessage="""<$radio tiddler=<<decisionTitle>> value="add"> add</$radio>
<$radio tiddler=<<decisionTitle>> value="skip"> skip</$radio>""">
<$radio tiddler=<<decisionTitle>> value="overwrite"> overwrite</$radio>
<$radio tiddler=<<decisionTitle>> value="rename"> rename</$radio>
<$radio tiddler=<<decisionTitle>> value="skip"> skip</$radio>
<$reveal type="match" stateTitle=<<decisionTitle>> text="rename" tag="div" class="jc-rename">
→ <span class={{{ [[jc-rename-input-wrap]] [<decisionTitle>!has[rename-title]then[jc-input-invalid]] [<decisionTitle>get[rename-title]match[]then[jc-input-invalid]] [<decisionTitle>get[rename-title]is[tiddler]then[jc-input-invalid]] +[join[ ]] }}}>
<$edit-text tiddler=<<decisionTitle>> field="rename-title" tag="input" placeholder=<<targetTitle>> default=<<targetTitle>>/>
</span>
<$list filter="[<decisionTitle>!has[rename-title]] [<decisionTitle>get[rename-title]match[]]" emptyMessage="" variable="_jc">
<span class="jc-rename-error">required</span>
</$list>
<$list filter="[<decisionTitle>get[rename-title]is[tiddler]]" emptyMessage="" variable="_jc">
<span class="jc-rename-error">title already exists</span>
</$list>
</$reveal>
</$list>
</div>

</div>

<$list filter="[<expandedTitle>get[text]match[yes]]" emptyMessage="" variable="_unused">
<div class="jc-expansion">

<table class="jc-fields-table">
<thead><tr><th>Field</th><th>Value</th></tr></thead>
<tbody>
<$list filter="[<stagedTitle>fields[]] -[[title]] -[[text]] -[[created]] -[[modified]] -[[_target-title]] -[[_collision]] +[sort[]]" variable="fieldName">
<tr><td><$text text=<<fieldName>>/></td><td>{{{ [<stagedTitle>get<fieldName>] }}}</td></tr>
</$list>
</tbody>
</table>

<div class="jc-staging-preview">
<$transclude $tiddler=<<stagedTitle>> $field="text" $type="text/vnd.tiddlywiki" $mode="block"/>
</div>

</div>
</$list>

</div>
</$let>
\end

\procedure jc-set-decisions(filter, action)
<$list filter=<<filter>> variable="stagedTitle">
<$let idx={{{ [<stagedTitle>removeprefix<staged-prefix>] }}}>
<$action-setfield $tiddler={{{ [<decisions-prefix>addsuffix<idx>] }}} text=<<action>>/>
</$let>
</$list>
\end

<$let
  state-base="$:/state/json-convert"
  staged-base="$:/temp/json-convert/staged"
  source-title={{{ [<state-base>addsuffix[/source]] }}}
  profile-title={{{ [<state-base>addsuffix[/profile]] }}}
  errors-title={{{ [<state-base>addsuffix[/result/errors]] }}}
  warnings-title={{{ [<state-base>addsuffix[/result/warnings]] }}}
  collisions-title={{{ [<state-base>addsuffix[/result/collisions]] }}}
  staged-prefix={{{ [<staged-base>addsuffix[/]] }}}
  decisions-prefix={{{ [<state-base>addsuffix[/decisions/]] }}}
  conflicts-filter="[prefix<staged-prefix>has[_collision]sort[]]"
  new-filter="[prefix<staged-prefix>!has[_collision]sort[]]"
>

A general-purpose JSON-to-tiddler conversion tool. Paste your source JSON,
pick a profile, and click ''Convert''.

!! 1. Source JSON

<div class="jc-source-toolbar">
<small>Paste below, drop a file, or:</small>
<$json-convert-browse-file target-title=<<source-title>>/>
</div>

<$json-convert-drop-file target-title=<<source-title>>>
<$edit-text
  tiddler=<<source-title>>
  tag="textarea"
  rows="14"
  placeholder="Paste JSON here, or drop a .json file…"
  class="tc-edit-texteditor jc-source-textarea"
/>
</$json-convert-drop-file>

<div class="jc-profile-header">

<div class="jc-profile-h">

!! 2. Profile

</div>

<div class="jc-profile-new">
<$button>
New…
<$action-setfield $tiddler="$:/state/json-convert/console/new-profile-name" text=""/>
<$action-sendmessage
  $message="tm-modal"
  $param="$:/plugins/crosseye/json-convert/NewProfileModal"/>
</$button>
</div>

<div class="jc-profile-select">
<$select tiddler=<<profile-title>>>
<option value="">— select a profile —</option>
<$list filter="[tag[$:/tags/json-convert/profile]sort[]]">
<option value=<<currentTiddler>>><$view field="title"/></option>
</$list>
</$select>
</div>

<div class="jc-profile-edit">
<$button
  disabled={{{ [<profile-title>get[text]!match[]is[tiddler]then[no]else[yes]] }}}
  tooltip={{{ [<profile-title>get[text]!match[]is[tiddler]then[Open the selected profile in the form-based editor]else[Select a profile first]] }}}>
Edit
<$action-setfield $tiddler="$:/state/json-convert/editor/profile-title" text={{{ [<profile-title>get[text]] }}}/>
<$json-convert-editor-init profile-title={{{ [<profile-title>get[text]] }}} draft-base="$:/state/json-convert/editor/draft/"/>
<$action-navigate $to="$:/plugins/crosseye/json-convert/Editor"/>
</$button>
</div>

</div>

!! 3. Run

<$button class="tc-btn-big-green">
Convert
<$json-convert-run state-base=<<state-base>> staged-base=<<staged-base>>/>
</$button>

!! Results

<$list filter="[<errors-title>has[title]]" emptyMessage="//No run yet — click ''Convert'' above.//" variable="ignore">

|!Category |!Count |
|Tiddlers staged |<$count filter="[prefix<staged-prefix>]"/> |
|Errors |<$count filter="[<errors-title>jsonindexes[]]"/> |
|Warnings |<$count filter="[<warnings-title>jsonindexes[]]"/> |
|Collisions |<$count filter="[<collisions-title>jsonindexes[]]"/> |

<$list filter="[<errors-title>jsonindexes[]first[]]" emptyMessage="" variable="_first">
<details><summary>Errors (<$count filter="[<errors-title>jsonindexes[]]"/>)</summary>
<$list filter="[<errors-title>jsonindexes[]]" variable="idx">
* ''{{{ [<errors-title>jsonget<idx>,[code]] }}}'' — {{{ [<errors-title>jsonget<idx>,[message]] }}}
</$list>
</details>
</$list>

<$list filter="[<warnings-title>jsonindexes[]first[]]" emptyMessage="" variable="_first">
<details><summary>Warnings (<$count filter="[<warnings-title>jsonindexes[]]"/>)</summary>
<$list filter="[<warnings-title>jsonindexes[]]" variable="idx">
* ''{{{ [<warnings-title>jsonget<idx>,[code]] }}}'' — {{{ [<warnings-title>jsonget<idx>,[message]] }}}
</$list>
</details>
</$list>

<$list filter="[<collisions-title>jsonindexes[]first[]]" emptyMessage="" variable="_first">
<details><summary>Collisions with existing titles (<$count filter="[<collisions-title>jsonindexes[]]"/>)</summary>
<$list filter="[<collisions-title>jsonindexes[]]" variable="idx">
* {{{ [<collisions-title>jsonget<idx>] }}}
</$list>
</details>
</$list>

</$list>

<$list filter="[prefix<staged-prefix>first[]]" emptyMessage="" variable="_first">

!! Staging

<$count filter="[prefix<staged-prefix>]"/> tiddlers staged. Pick an action for each, then click ''Apply'' to write them to the wiki, or ''Cancel'' to discard.

<$list filter="[prefix<staged-prefix>has[_collision]first[]]" emptyMessage="" variable="_first">

!!! Conflicts (<$count filter="[prefix<staged-prefix>has[_collision]]"/>)

These titles already exist in the wiki. Default action is ''skip''.

<div class="jc-bulk-actions">
<span class="jc-bulk-label">Set all to:</span>
<$button>
Skip
<<jc-set-decisions "[prefix<staged-prefix>has[_collision]]" "skip">>
</$button>
<$button>
Overwrite
<<jc-set-decisions "[prefix<staged-prefix>has[_collision]]" "overwrite">>
</$button>
</div>

<$list filter=<<conflicts-filter>> variable="stagedTitle">
<<jc-staging-row>>
</$list>

</$list>

<$list filter="[prefix<staged-prefix>!has[_collision]first[]]" emptyMessage="" variable="_first">

!!! New (<$count filter="[prefix<staged-prefix>!has[_collision]]"/>)

<div class="jc-bulk-actions">
<span class="jc-bulk-label">Set all to:</span>
<$button>
Add
<<jc-set-decisions "[prefix<staged-prefix>!has[_collision]]" "add">>
</$button>
<$button>
Skip
<<jc-set-decisions "[prefix<staged-prefix>!has[_collision]]" "skip">>
</$button>
</div>

<$list filter=<<new-filter>> variable="stagedTitle">
<<jc-staging-row>>
</$list>

</$list>

<$let
  total-renames={{{ [prefix<decisions-prefix>field:text[rename]count[]] }}}
  valid-renames={{{ [prefix<decisions-prefix>field:text[rename]] :filter[get[rename-title]!is[tiddler]!match[]] +[count[]] }}}
  renames-ok={{{ [<total-renames>match<valid-renames>then[yes]else[no]] }}}
>
<$button class={{{ [<renames-ok>match[no]then[tc-btn-big-green jc-btn-disabled]else[tc-btn-big-green]] }}} disabled={{{ [<renames-ok>match[no]then[yes]] }}}>
Apply
<$json-convert-apply state-base=<<state-base>> staged-base=<<staged-base>>/>
</$button>
<$button>
Cancel
<$list filter="[prefix<staged-prefix>]" variable="t">
<$action-deletetiddler $tiddler=<<t>>/>
</$list>
<$list filter="[prefix<decisions-prefix>]" variable="t">
<$action-deletetiddler $tiddler=<<t>>/>
</$list>
</$button>
<$list filter="[<renames-ok>match[no]]" emptyMessage="" variable="_jc">
<span class="jc-apply-blocked">Resolve invalid rename titles before applying.</span>
</$list>
</$let>

</$list>

<$let audit-title="$:/temp/json-convert/audit-log">
<$list filter="[<audit-title>has[list]]" emptyMessage="" variable="_jc">

!! Imported this session

<$count filter="[list[$:/temp/json-convert/audit-log!!list]]"/> tiddlers written to the wiki since this session was loaded.  Click a title to view; click ''Clear log'' to forget (the wiki contents are not affected).

<ul class="jc-audit-list">
<$list filter="[list[$:/temp/json-convert/audit-log!!list]]" variable="t">
<li><$link to=<<t>>><$text text=<<t>>/></$link></li>
</$list>
</ul>

<$button>
Clear log
<$action-deletetiddler $tiddler=<<audit-title>>/>
</$button>

</$list>
</$let>

</$let>
